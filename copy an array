// to copy an array 
#include <stdio.h>

int main() 
{
  int i,n;
 
  printf("Enter the size of the array:\n");
  scanf("%d",&n);
  int a[n];
  int b[n];
  printf("enter the elements in the array:\n");
  for(i=0;i<n;i++)
  {
      scanf("%d",&a[i]);
  }
  for(i=0;i<n;i++)
  {
      b[i]=a[i];
  }
  printf("the elements of an copied array:\n");
  for(i=0;i<n;i++)
  {
      printf("%d \t",b[i]);
  }
  return 0;
}

 
