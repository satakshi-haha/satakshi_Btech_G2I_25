// To check a palindrome number
#include <stdio.h>

int main() 
{
  int n,dig,rev=0,t=0;
  printf("Enter the number:\n");
  scanf("%d",&n);
  t=n;
  
  while(n>0)
  {
      dig=n%10;
      rev=(rev*10)+dig;
      n=n/10;
  }
  
  if(rev==t)
  {
      printf("Number is palindrome");
  }
  else
  {
      printf("Number is NOT palindrome");
  }
 return 0;
}


