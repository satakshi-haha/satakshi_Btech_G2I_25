//sum of an array
#include <stdio.h>

int main() 
{
  int i,n,s=0;
 
  printf("Enter the size of the array:\n");
  scanf("%d",&n);
  int a[n];
  printf("enter the elements in the array:\n");
  for(i=0;i<n;i++)
  {
      scanf("%d",&a[i]);
  }
  for(i=0;i<n;i++)
  {
      s=s+a[i];
  }
  printf("the sum of elements of an array: %d",s);
  return 0;
}

 
