// to reverse the array
#include <stdio.h>

int main() 
{
  int i,n;
 
  printf("Enter the size of the array:\n");
  scanf("%d",&n);
  int a[n];
  
  printf("enter the elements in the array:\n");
  for(i=0;i<n;i++)
  {
      scanf("%d",&a[i]);
  }
  
  printf("the reversed array is:\n");
  for(i=n-1;i>=0;i--)
  {
     printf("%d\t",a[i]);
  }
  return 0;
}

 
