// count of even or odd in an array
#include <stdio.h>

int main() 
{
  int i,n,e=0,o=0;
 
  printf("Enter the size of the array:\n");
  scanf("%d",&n);
  int a[n];
  
  printf("enter the elements in the array:\n");
  for(i=0;i<n;i++)
  {
      scanf("%d",&a[i]);
  }
  for(i=0;i<n;i++)
  {
     if(a[i]%2==0)
     {
         e++;
     }
     else
     {
         o++;
     }
     
  }
  printf("the number of odd elements in an array: %d\n",o);
  printf("the number of even elements in an array: %d\n",e);
  return 0;
}

 
