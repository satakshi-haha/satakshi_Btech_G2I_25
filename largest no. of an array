// to find the largest number of an array
#include <stdio.h>

int main() 
{
  int i,n;
 
  printf("Enter the size of the array:\n");
  scanf("%d",&n);
  int a[n];
  
  printf("enter the elements in the array:\n");
  for(i=0;i<n;i++)
  {
      scanf("%d",&a[i]);
  }
  int max= a[0];
  for(i=0;i<n;i++)
  {
     if(a[i]>max)
     {
         max=a[i];
     }
     
  }
  printf("the largest value of an array: %d\n",max);
  return 0;
}

 
